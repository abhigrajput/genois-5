# Secrets — never commit real keys
.env

# Virtual environments
.venv/
venv/
env/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Packaging / build artifacts
*.egg-info/
build/
dist/

# Downloaded model caches (faster-whisper / Hugging Face)
.cache/
models/
*.bin

# Temporary TTS audio
*.mp3
*.wav

# Saved conversation history (may contain personal content)
conversation_history.json

# Saved user profile (name, etc.)
user_profile.json

# Scheduler cadence (may hold personal times) — schedule.example.json is tracked
schedule.json

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
