# Copy this file to ".env" and fill in your real keys.
# Do NOT commit the real .env to git.

# --- Claude (Anthropic) ---
# Used for complex reasoning, advice, planning, mentoring, AND to classify each
# turn as chat vs. a PC command (intent routing).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Fast, cheap model used only for intent classification on every turn.
# Override only if you want a different classifier model.
INTENT_MODEL=claude-haiku-4-5-20251001

# --- MiniMax M3 ---
# Used for fast, simple replies (chit-chat, short factual answers).
# Served via NVIDIA NIM, which exposes an OpenAI-compatible chat endpoint.
# Get an NVIDIA API key (starts with "nvapi-") from https://build.nvidia.com.
MINIMAX_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://integrate.api.nvidia.com/v1
# Model id as served by the endpoint above. Override only if you switch providers.
MINIMAX_MODEL=minimaxai/minimax-m3
# MINIMAX_GROUP_ID is only required by MiniMax's own API. Leave blank for NVIDIA NIM.
MINIMAX_GROUP_ID=

# --- Supabase (accountability mentor store, Phase 3) ---
# Backs the mentor brain's commitments, facts, and check-ins. Find these in your
# Supabase project under Settings -> API. Use the SERVICE ROLE key (secret), not
# the anon key, so Jarvis can read/write past row-level security. Leave both
# blank to run without the mentor (chat + PC control still work).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Speech-to-text (Whisper) ---
# Language Whisper transcribes in (auto-detect is unreliable on short clips).
# Use "en" for English/Hinglish, "hi" for mostly-Hindi speech, or any Whisper code.
WHISPER_LANGUAGE=en
