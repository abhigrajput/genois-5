# Copy this file to ".env" and fill in your real keys.
# Do NOT commit the real .env to git.

# --- Claude (Anthropic) ---
# Used for complex reasoning, advice, planning, mentoring.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MiniMax M3 ---
# Used for fast, simple replies (chit-chat, short factual answers).
# Served via NVIDIA NIM, which exposes an OpenAI-compatible chat endpoint.
# Get an NVIDIA API key (starts with "nvapi-") from https://build.nvidia.com.
MINIMAX_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://integrate.api.nvidia.com/v1
# Model id as served by the endpoint above. Override only if you switch providers.
MINIMAX_MODEL=minimaxai/minimax-m3
# MINIMAX_GROUP_ID is only required by MiniMax's own API. Leave blank for NVIDIA NIM.
MINIMAX_GROUP_ID=
